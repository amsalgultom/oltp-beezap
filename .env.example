# ============================================================================
# Beezap analytics — environment configuration
#
# Copy this file to `.env` (same directory as docker-compose.yml) and fill
# in real values. `.env` should NOT be committed to version control.
# ============================================================================

# ============================================================================
# Server A — existing Postgres OLTP database (read by Debezium)
# ============================================================================
PG_HOST=10.10.8.93
PG_PORT=5432
PG_DATABASE=whatsapp_multi_tenant
DEBEZIUM_DB_USER=debezium
DEBEZIUM_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================================================
# Server B — existing Kafka cluster
# ============================================================================
KAFKA_BOOTSTRAP_SERVERS=10.10.8.60:9092

# ============================================================================
# Kafka Connect (runs on this new server)
# ============================================================================
CONNECT_GROUP_ID=beezap-connect-cluster
CONNECT_URL=http://localhost:8083

# ============================================================================
# ClickHouse (runs on this new server)
# Consumes CDC topics from Kafka. Superset queries data FROM HERE.
# ============================================================================
CLICKHOUSE_DB=beezap
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================================================
# Superset (runs on this new server)
# ============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SUPERSET_SECRET_KEY=CHANGE_ME_RANDOM_SECRET

SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_ADMIN_FIRSTNAME=Admin
SUPERSET_ADMIN_LASTNAME=User

# Superset's own metadata database (on Server A Postgres, not local container)
# Stores dashboards, charts, users, datasource connections, etc.
SUPERSET_DB_HOST=10.10.8.93
SUPERSET_DB_PORT=5432
SUPERSET_DB_USER=postgres
PG_SUPERUSER_PASSWORD=CHANGE_ME_POSTGRES_SUPERUSER_PASSWORD
SUPERSET_DB_NAME=superset

# ============================================================================
# Redis (external, on Server A)
# Caches Superset results/filters/form data
# ============================================================================
REDIS_URL=redis://10.10.8.93:6379/3
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
