# ============================================================================
# Beezap Analytics — Next.js frontend environment
# Copy to .env.local and fill in values.
# ============================================================================

# PostgreSQL connection for Prisma (app's own schema — same Postgres as Superset OK)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=SCHEMA
DATABASE_URL="postgresql://postgres:CHANGE_ME@10.10.8.93:5432/superset?schema=beezap_app"

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_RANDOM_SECRET"

# Full public URL of this Next.js app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"
